{
    "name": "n8n-nodes-lenz",
    "version": "0.1.0",
    "description": "Fact-check claims and catch AI hallucinations with Lenz - verified, sourced verdicts inside your n8n workflows.",
    "license": "MIT",
    "homepage": "https://lenz.io",
    "keywords": [
        "n8n-community-node-package"
    ],
    "author": {
        "name": "David Yordanov",
        "email": "yordanovdavid@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/lenzhq/n8n-nodes-lenz.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": false,
        "credentials": [
            "dist/credentials/LenzApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/Lenz/Lenz.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "dependencies": {
        "lenz-io": "^2.3.0"
    }
}
